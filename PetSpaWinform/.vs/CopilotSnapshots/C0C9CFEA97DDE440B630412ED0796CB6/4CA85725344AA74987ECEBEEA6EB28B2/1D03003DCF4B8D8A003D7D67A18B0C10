using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;
using MySql.Data.MySqlClient;

namespace GD
{
    public partial class QLNCC : Form
    {
        private readonly string connectionString = "Server=127.0.0.1;Database=spathucung;User=root;Password=;";
        private DataTable originalTable; // Để tìm kiếm nhanh
        public QLNCC()
        {
            InitializeComponent();
            LoadSuppliers();
            SetupDataGridView();
        }
        private void LoadSuppliers()
        {
            using (MySqlConnection conn = new MySqlConnection(connectionString))
            {
                try
                {
                    conn.Open();
                    string query = @"
                        SELECT 
                            supplier_id AS 'Mã NCC',
                            name AS 'Tên nhà cung cấp',
                            phone AS 'Số điện thoại',
                            email AS 'Email',
                            address AS 'Địa chỉ',
                            bank_account AS 'Tài khoản ngân hàng'
                        FROM suppliers
                        ORDER BY name";

                    MySqlDataAdapter da = new MySqlDataAdapter(query, conn);
                    DataTable dt = new DataTable();
                    da.Fill(dt);

                    // Lưu bảng gốc để tìm kiếm nhanh
                    originalTable = dt.Copy();

                    dgvNCC.DataSource = originalTable;

                    // Ẩn cột Mã NCC (dùng nội bộ)
                    if (dgvNCC.Columns["Mã NCC"] != null)
                        dgvNCC.Columns["Mã NCC"].Visible = false;

                    // Định dạng đẹp
                    dgvNCC.Columns["Tên nhà cung cấp"].Width = 200;
                    dgvNCC.Columns["Địa chỉ"].AutoSizeMode = DataGridViewAutoSizeColumnMode.Fill;
                }
                catch (Exception ex)
                {
                    MessageBox.Show("Lỗi tải dữ liệu: " + ex.Message, "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            }
        }
        private void SetupDataGridView()
        {
            dgvNCC.AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill;
            dgvNCC.ReadOnly = true;
            dgvNCC.SelectionMode = DataGridViewSelectionMode.FullRowSelect;
            dgvNCC.MultiSelect = false;
            dgvNCC.RowHeadersVisible = false;
            dgvNCC.BackgroundColor = Color.White;
            dgvNCC.AlternatingRowsDefaultCellStyle.BackColor = Color.FromArgb(245, 250, 255);

            // Header đẹp
            dgvNCC.EnableHeadersVisualStyles = false;
            dgvNCC.ColumnHeadersDefaultCellStyle.BackColor = Color.FromArgb(30, 144, 255);
            dgvNCC.ColumnHeadersDefaultCellStyle.ForeColor = Color.White;
            dgvNCC.ColumnHeadersDefaultCellStyle.Font = new Font("Segoe UI", 10F, FontStyle.Bold);
            dgvNCC.ColumnHeadersHeight = 40;
            dgvNCC.AllowUserToResizeRows = false;
        }

        private void dgvNCC_CellClick(object sender, DataGridViewCellEventArgs e)
        {
            if (e.RowIndex >= 0)
            {
                DataGridViewRow row = dgvNCC.Rows[e.RowIndex];

              
                txtTenNCC.Text = row.Cells["Tên nhà cung cấp"].Value?.ToString() ?? "";
                txtDiaChi.Text = row.Cells["Địa chỉ"].Value?.ToString() ?? "";
                txtSDT.Text = row.Cells["Số điện thoại"].Value?.ToString() ?? "";
                txtEmail.Text = row.Cells["Email"].Value?.ToString() ?? "";
                txtTKBank.Text = row.Cells["Tài khoản ngân hàng"].Value?.ToString() ?? "";
            }
        }

        private void txtTimKiem_TextChanged(object sender, EventArgs e)
        {
            if (originalTable == null) return;

            string keyword = txtTimKiem.Text.Trim();

            if (string.IsNullOrEmpty(keyword))
            {
                originalTable.DefaultView.RowFilter = "1=1";
            }
            else
            {
                string filter = $"( [Tên nhà cung cấp] LIKE '%{keyword}%' " +
                               $"OR [Số điện thoại] LIKE '%{keyword}%' " +
                               $"OR [Email] LIKE '%{keyword}%' " +
                               $"OR [Địa chỉ] LIKE '%{keyword}%' )";

                originalTable.DefaultView.RowFilter = filter;
            }
        }
        private void ClearForm()
        {
          
            txtTenNCC.Clear();
            txtDiaChi.Clear();
            txtSDT.Clear();
            txtEmail.Clear();
            txtTKBank.Clear();
            txtTimKiem.Clear();
            txtTenNCC.Focus();
        }
        private void btnThem_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrWhiteSpace(txtTenNCC.Text))
            {
                MessageBox.Show("Vui lòng nhập tên nhà cung cấp!", "Thiếu thông tin", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                txtTenNCC.Focus();
                return;
            }

            using (MySqlConnection conn = new MySqlConnection(connectionString))
            {
                try
                {
                    conn.Open();
                    string query = @"
                        INSERT INTO suppliers (name, phone, email, address, bank_account)
                        VALUES (@name, @phone, @email, @address, @bank)";

                    MySqlCommand cmd = new MySqlCommand(query, conn);
                    cmd.Parameters.AddWithValue("@name", txtTenNCC.Text.Trim());
                    cmd.Parameters.AddWithValue("@phone", txtSDT.Text.Trim());
                    cmd.Parameters.AddWithValue("@email", txtEmail.Text.Trim());
                    cmd.Parameters.AddWithValue("@address", txtDiaChi.Text.Trim());
                    cmd.Parameters.AddWithValue("@bank", txtTKBank.Text.Trim());

                    cmd.ExecuteNonQuery();
                    MessageBox.Show("Thêm nhà cung cấp thành công!", "Thành công", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    LoadSuppliers();
                    ClearForm();
                }
                catch (Exception ex)
                {
                    MessageBox.Show("Lỗi: " + ex.Message, "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            }
        }

        private void btnXoa_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrEmpty(txtMaNCC.Text))
            {
                MessageBox.Show("Vui lòng chọn nhà cung cấp cần xóa!", "Thông báo", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            if (MessageBox.Show("Bạn có chắc chắn muốn xóa nhà cung cấp này?\n\nDữ liệu liên quan (phiếu nhập) cũng sẽ bị ảnh hưởng!",
                "Xác nhận xóa", MessageBoxButtons.YesNo, MessageBoxIcon.Question) == DialogResult.Yes)
            {
                using (MySqlConnection conn = new MySqlConnection(connectionString))
                {
                    try
                    {
                        conn.Open();
                        string query = "DELETE FROM suppliers WHERE supplier_id = @id";
                        MySqlCommand cmd = new MySqlCommand(query, conn);
                        cmd.Parameters.AddWithValue("@id", int.Parse(txtMaNCC.Text));
                        cmd.ExecuteNonQuery();

                        MessageBox.Show("Xóa thành công!", "Thành công", MessageBoxButtons.OK, MessageBoxIcon.Information);
                        LoadSuppliers();
                        ClearForm();
                    }
                    catch (Exception ex)
                    {
                        MessageBox.Show("Không thể xóa vì nhà cung cấp đang có phiếu nhập!\n" + ex.Message, "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Stop);
                    }
                }
            }
        }

        private void btnSua_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrEmpty(txtMaNCC.Text))
            {
                MessageBox.Show("Vui lòng chọn nhà cung cấp cần sửa!", "Thông báo", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            using (MySqlConnection conn = new MySqlConnection(connectionString))
            {
                try
                {
                    conn.Open();
                    string query = @"
                        UPDATE suppliers SET
                            name = @name,
                            phone = @phone,
                            email = @email,
                            address = @address,
                            bank_account = @bank
                        WHERE supplier_id = @id";

                    MySqlCommand cmd = new MySqlCommand(query, conn);
                    cmd.Parameters.AddWithValue("@id", int.Parse(txtMaNCC.Text));
                    cmd.Parameters.AddWithValue("@name", txtTenNCC.Text.Trim());
                    cmd.Parameters.AddWithValue("@phone", txtSDT.Text.Trim());
                    cmd.Parameters.AddWithValue("@email", txtEmail.Text.Trim());
                    cmd.Parameters.AddWithValue("@address", txtDiaChi.Text.Trim());
                    cmd.Parameters.AddWithValue("@bank", txtTKBank.Text.Trim());

                    cmd.ExecuteNonQuery();
                    MessageBox.Show("Cập nhật thành công!", "Thành công", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    LoadSuppliers();
                    ClearForm();
                }
                catch (Exception ex)
                {
                    MessageBox.Show("Lỗi: " + ex.Message);
                }
            }
        }

    }
}
