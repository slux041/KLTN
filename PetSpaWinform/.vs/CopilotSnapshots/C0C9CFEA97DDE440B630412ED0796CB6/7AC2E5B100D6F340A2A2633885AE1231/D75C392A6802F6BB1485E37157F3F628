using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;
using MySql.Data.MySqlClient;

namespace GD
{
    public partial class QLPN : Form
    {
        private readonly string connectionString = "Server=127.0.0.1;Database=spathucung;user=root;password=;";
        private DataTable originalTable;
        private int currentPurchaseOrderId = 0;
        public QLPN()
        {
            InitializeComponent();
            LoadPurchaseOrders();
            LoadSuppliersToComboBox();
            LoadStaffToComboBox();
            SetupDataGridView();
        }
        private void LoadPurchaseOrders()
        {
            using (MySqlConnection conn = new MySqlConnection(connectionString))
            {
                try
                {
                    conn.Open();
                    string query = @"
                        SELECT 
                            po.purchase_order_id AS 'Mã phiếu',
                            s.name AS 'Nhà cung cấp',
                            u.full_name AS 'Nhân viên',
                            po.created_at AS 'Ngày nhập',
                            po.total_amount AS 'Tổng tiền'
                        FROM purchase_orders po
                        JOIN suppliers s ON po.supplier_id = s.supplier_id
                        JOIN users u ON po.user_id = u.user_id
                        ORDER BY po.created_at DESC";

                    MySqlDataAdapter da = new MySqlDataAdapter(query, conn);
                    DataTable dt = new DataTable();
                    da.Fill(dt);

                    originalTable = dt.Copy();
                    dgvPhieuNhap.DataSource = originalTable;

                    // Định dạng
                    dgvPhieuNhap.Columns["Tổng tiền"].DefaultCellStyle.Format = "N0";
                    dgvPhieuNhap.Columns["Tổng tiền"].DefaultCellStyle.Alignment = DataGridViewContentAlignment.MiddleRight;
                    dgvPhieuNhap.Columns["Ngày nhập"].DefaultCellStyle.Format = "dd/MM/yyyy HH:mm";
                }
                catch (Exception ex)
                {
                    MessageBox.Show("Lỗi tải phiếu nhập: " + ex.Message);
                }
            }

        }
        private void LoadSuppliersToComboBox()
        {
            using (MySqlConnection conn = new MySqlConnection(connectionString))
            {
                conn.Open();
                string query = "SELECT supplier_id, name FROM suppliers ORDER BY name";
                MySqlDataAdapter da = new MySqlDataAdapter(query, conn);
                DataTable dt = new DataTable();
                da.Fill(dt);

                cmbNCC.DisplayMember = "name";
                cmbNCC.ValueMember = "supplier_id";
                cmbNCC.DataSource = dt;
            }
        }
        private void LoadStaffToComboBox()
        {
            using (MySqlConnection conn = new MySqlConnection(connectionString))
            {
                conn.Open();
                string query = "SELECT user_id, full_name FROM users WHERE role IN ('admin', 'staff') ORDER BY full_name";
                MySqlDataAdapter da = new MySqlDataAdapter(query, conn);
                DataTable dt = new DataTable();
                da.Fill(dt);

                cmbNV.DisplayMember = "full_name";
                cmbNV.ValueMember = "user_id";
                cmbNV.DataSource = dt;
            }
        }
        private void SetupDataGridView()
        {
            dgvPhieuNhap.AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill;
            dgvPhieuNhap.ReadOnly = true;
            dgvPhieuNhap.SelectionMode = DataGridViewSelectionMode.FullRowSelect;
            dgvPhieuNhap.RowHeadersVisible = false;
            dgvPhieuNhap.BackgroundColor = Color.White;
            dgvPhieuNhap.AlternatingRowsDefaultCellStyle.BackColor = Color.FromArgb(245, 250, 255);

            dgvPhieuNhap.EnableHeadersVisualStyles = false;
            dgvPhieuNhap.ColumnHeadersDefaultCellStyle.BackColor = Color.FromArgb(30, 144, 255);
            dgvPhieuNhap.ColumnHeadersDefaultCellStyle.ForeColor = Color.White;
            dgvPhieuNhap.ColumnHeadersDefaultCellStyle.Font = new Font("Segoe UI", 10F, FontStyle.Bold);
            dgvPhieuNhap.ColumnHeadersHeight = 40;

            // Setup detail grid
            if (dgvChiTiet != null)
            {
                dgvChiTiet.AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill;
                dgvChiTiet.ReadOnly = true;
                dgvChiTiet.SelectionMode = DataGridViewSelectionMode.FullRowSelect;
                dgvChiTiet.RowHeadersVisible = false;
                dgvChiTiet.BackgroundColor = Color.White;
                dgvChiTiet.ColumnHeadersDefaultCellStyle.BackColor = Color.FromArgb(30, 144, 255);
                dgvChiTiet.ColumnHeadersDefaultCellStyle.ForeColor = Color.White;
                dgvChiTiet.ColumnHeadersDefaultCellStyle.Font = new Font("Segoe UI", 10F, FontStyle.Bold);
                dgvChiTiet.ColumnHeadersHeight = 40;
            }
        }

        private void dgvPhieuNhap_CellClick(object sender, DataGridViewCellEventArgs e)
        {
            if (e.RowIndex >= 0)
            {
                DataGridViewRow row = dgvPhieuNhap.Rows[e.RowIndex];
                currentPurchaseOrderId = Convert.ToInt32(row.Cells["Mã phiếu"].Value);

                lblMaPN.Text = currentPurchaseOrderId.ToString();
                cmbNCC.Text = row.Cells["Nhà cung cấp"].Value.ToString();
                cmbNV.Text = row.Cells["Nhân viên"].Value.ToString();
                dtpNgayNhap.Value = Convert.ToDateTime(row.Cells["Ngày nhập"].Value);
                lblTongTien.Text = string.Format("{0:N0} đ", row.Cells["Tổng tiền"].Value);

                // Load details for selected purchase order
                LoadPurchaseOrderDetails(currentPurchaseOrderId);
            }
        }

        private void LoadPurchaseOrderDetails(int purchaseOrderId)
        {
            using (MySqlConnection conn = new MySqlConnection(connectionString))
            {
                try
                {
                    conn.Open();
                    string query = @"
                        SELECT 
                            p.product_id AS 'Mã SP',
                            p.name AS 'Sản phẩm',
                            pod.quantity AS 'Số lượng',
                            pod.unit_price AS 'Giá nhập',
                            (pod.quantity * pod.unit_price) AS 'Thành tiền'
                        FROM purchase_order_details pod
                        JOIN products p ON pod.product_id = p.product_id
                        WHERE pod.purchase_order_id = @poId";

                    MySqlCommand cmd = new MySqlCommand(query, conn);
                    cmd.Parameters.AddWithValue("@poId", purchaseOrderId);
                    MySqlDataAdapter da = new MySqlDataAdapter(cmd);
                    DataTable dt = new DataTable();
                    da.Fill(dt);

                    if (dgvChiTiet != null)
                    {
                        dgvChiTiet.DataSource = dt;
                        if (dgvChiTiet.Columns["Giá nhập"] != null)
                        {
                            dgvChiTiet.Columns["Giá nhập"].DefaultCellStyle.Format = "N0";
                            dgvChiTiet.Columns["Thành tiền"].DefaultCellStyle.Format = "N0";
                            dgvChiTiet.Columns["Giá nhập"].DefaultCellStyle.Alignment = DataGridViewContentAlignment.MiddleRight;
                            dgvChiTiet.Columns["Thành tiền"].DefaultCellStyle.Alignment = DataGridViewContentAlignment.MiddleRight;
                        }
                    }
                }
                catch (Exception ex)
                {
                    MessageBox.Show("Lỗi tải chi tiết phiếu: " + ex.Message);
                }
            }
        }
    }
}
