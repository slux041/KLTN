using System;
using System.Data;
using System.Drawing;
using System.Windows.Forms;
using MySql.Data.MySqlClient;

namespace GD
{
    public partial class QLDH : Form
    {
        private readonly string connectionString = "Server=127.0.0.1;Database=spathucung;user=root;password=;";

        public QLDH()
        {
            InitializeComponent();
            InitializeTrangThai();
            InitializeComboBox();
            LoadDonHang();
        }
        private void InitializeTrangThai()
        {
            cmbTrangThai.Items.Clear();
            cmbTrangThai.Items.Add("Chờ xác nhận");
            cmbTrangThai.Items.Add("Đang xử lý");
            cmbTrangThai.Items.Add("Đã thanh toán");
            cmbTrangThai.Items.Add("Đã hủy");
            cmbTrangThai.SelectedIndex = -1;
            cmbTrangThai.Text = "";
        }
        private void LoadDonHang()
        {
            try
            {
                using (MySqlConnection conn = new MySqlConnection(connectionString))
                {
                    conn.Open();

                    string query = @"
                        SELECT
                            MaDH AS 'Mã đơn hàng',
                            NgayDat AS 'Ngày đặt',
                            TrangThai AS 'Trạng thái',
                            TongTien AS 'Tổng tiền',
                            HinhThucThanhToan AS 'Hình thức thanh toán',
                            MaKH AS 'Mã khách hàng'
                        FROM DonHang
                        WHERE 1=1";

                    MySqlCommand cmd = new MySqlCommand();
                    cmd.Connection = conn;

                    // Lọc theo thời gian
                    string selected = cmbTimKiemTG.SelectedItem?.ToString();

                    if (!string.IsNullOrEmpty(selected) && selected != "Tất cả")
                    {
                        DateTime fromDate = DateTime.Today;
                        DateTime toDate = DateTime.Today.AddDays(1);

                        switch (selected)
                        {
                            case "Hôm nay": fromDate = DateTime.Today; break;
                            case "7 ngày trước": fromDate = DateTime.Today.AddDays(-6); break;
                            case "1 tháng trước": fromDate = DateTime.Today.AddMonths(-1); break;
                            case "3 tháng trước": fromDate = DateTime.Today.AddMonths(-3); break;
                        }

                        query += " AND NgayDat >= @FromDate AND NgayDat < @ToDate";
                        cmd.Parameters.AddWithValue("@FromDate", fromDate);
                        cmd.Parameters.AddWithValue("@ToDate", toDate);
                    }

                    // Lọc theo mã khách hàng
                    if (!string.IsNullOrEmpty(txtTimKiemMa.Text.Trim()))
                    {
                        query += " AND MaDH LIKE @MaDH";
                        cmd.Parameters.AddWithValue("@MaDH", "%" + txtTimKiemMa.Text.Trim() + "%");
                    }

                    cmd.CommandText = query;

                    MySqlDataAdapter adapter = new MySqlDataAdapter(cmd);
                    DataTable dt = new DataTable();
                    adapter.Fill(dt);

                    dgvDonHang.DataSource = dt;
                    SetupDataGridView();
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi lọc đơn hàng: " + ex.Message);
            }
        }

        // ===================== FORMAT BẢNG =====================
        private void SetupDataGridView()
        {
            var dgv = dgvDonHang;

            dgv.BorderStyle = BorderStyle.None;
            dgv.BackgroundColor = Color.White;
            dgv.AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill;
            dgv.EnableHeadersVisualStyles = false;
            dgv.ColumnHeadersDefaultCellStyle.BackColor = Color.FromArgb(30, 144, 255);
            dgv.ColumnHeadersDefaultCellStyle.ForeColor = Color.White;
            dgv.ColumnHeadersDefaultCellStyle.Font = new Font("Segoe UI", 11, FontStyle.Bold);
            dgv.ColumnHeadersHeight = 40;
            dgv.DefaultCellStyle.Font = new Font("Segoe UI", 11);
            dgv.DefaultCellStyle.BackColor = Color.White;
            dgv.DefaultCellStyle.ForeColor = Color.Black;
            dgv.DefaultCellStyle.SelectionBackColor = Color.FromArgb(255, 230, 150);
            dgv.DefaultCellStyle.SelectionForeColor = Color.Black;
            dgv.AlternatingRowsDefaultCellStyle.BackColor = Color.FromArgb(245, 245, 245);
            dgv.CellBorderStyle = DataGridViewCellBorderStyle.SingleHorizontal;
            dgv.GridColor = Color.LightGray;
            dgv.ReadOnly = true;
            dgv.SelectionMode = DataGridViewSelectionMode.FullRowSelect;
            dgv.RowHeadersVisible = false;
            dgv.RowTemplate.Height = 35;
        }
        private void dgvDonHang_CellClick(object sender, DataGridViewCellEventArgs e)
        {
            if (e.RowIndex >= 0)
            {
                txtMaDH.Text = dgvDonHang.Rows[e.RowIndex].Cells["Mã đơn hàng"].Value.ToString();
                cmbTrangThai.Text = dgvDonHang.Rows[e.RowIndex].Cells["Trạng thái"].Value.ToString();
                txtTongTien.Text = dgvDonHang.Rows[e.RowIndex].Cells["Tổng tiền"].Value.ToString();
                txtHinhThuc.Text = dgvDonHang.Rows[e.RowIndex].Cells["Hình thức thanh toán"].Value.ToString();
                txtmaKH.Text = dgvDonHang.Rows[e.RowIndex].Cells["Mã khách hàng"].Value.ToString();

                dtpNgayDat.Value = Convert.ToDateTime(dgvDonHang.Rows[e.RowIndex].Cells["Ngày đặt"].Value);
            }
        }

        // ===================== COMBOBOX LỌC THỜI GIAN =====================
        private void InitializeComboBox()
        {
            cmbTimKiemTG.Items.Clear();
            cmbTimKiemTG.Items.Add("Hôm nay");
            cmbTimKiemTG.Items.Add("7 ngày trước");
            cmbTimKiemTG.Items.Add("1 tháng trước");
            cmbTimKiemTG.Items.Add("3 tháng trước");
            cmbTimKiemTG.SelectedIndex = -1;
            cmbTimKiemTG.Text = "";
        }

        private void cmbTimKiemTG_SelectedIndexChanged(object sender, EventArgs e)
        {
            LoadDonHang();
        }

        private void txtTimKiemMa_TextChanged(object sender, EventArgs e)
        {
            LoadDonHang();
        }
        private void btnThem_Click(object sender, EventArgs e)
        {
            if (txtMaDH.Text == "" || txtmaKH.Text == "" || cmbTrangThai.SelectedIndex == -1)
            {
                MessageBox.Show("Vui lòng nhập đầy đủ thông tin!");
                return;
            }

            try
            {
                using (MySqlConnection conn = new MySqlConnection(connectionString))
                {
                    conn.Open();

                    string query = @"
                        INSERT INTO DonHang (MaDH, NgayDat, TrangThai, TongTien, HinhThucThanhToan, MaKH)
                        VALUES (@MaDH, @NgayDat, @TrangThai, @TongTien, @HinhThuc, @MaKH)";

                    MySqlCommand cmd = new MySqlCommand(query, conn);

                    cmd.Parameters.AddWithValue("@MaDH", txtMaDH.Text.Trim());
                    cmd.Parameters.AddWithValue("@NgayDat", dtpNgayDat.Value);
                    cmd.Parameters.AddWithValue("@TrangThai", cmbTrangThai.Text.Trim());
                    cmd.Parameters.AddWithValue("@TongTien", txtTongTien.Text.Trim());
                    cmd.Parameters.AddWithValue("@HinhThuc", txtHinhThuc.Text.Trim());
                    cmd.Parameters.AddWithValue("@MaKH", txtmaKH.Text.Trim());

                    cmd.ExecuteNonQuery();

                    MessageBox.Show("Thêm đơn hàng thành công!");
                    LoadDonHang();
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi thêm: " + ex.Message);
            }
        }
        private void btnSua_Click(object sender, EventArgs e)
        {
            if (txtMaDH.Text.Trim() == "")
            {
                MessageBox.Show("Chọn đơn hàng để sửa!");
                return;
            }

            try
            {
                using (MySqlConnection conn = new MySqlConnection(connectionString))
                {
                    conn.Open();

                    string query = @"
                        UPDATE DonHang
                        SET 
                            NgayDat = @NgayDat,
                            TrangThai = @TrangThai,
                            TongTien = @TongTien,
                            HinhThucThanhToan = @HinhThuc,
                            MaKH = @MaKH
                        WHERE MaDH = @MaDH";

                    MySqlCommand cmd = new MySqlCommand(query, conn);

                    cmd.Parameters.AddWithValue("@MaDH", txtMaDH.Text.Trim());
                    cmd.Parameters.AddWithValue("@NgayDat", dtpNgayDat.Value);
                    cmd.Parameters.AddWithValue("@TrangThai", cmbTrangThai.Text.Trim());
                    cmd.Parameters.AddWithValue("@TongTien", txtTongTien.Text.Trim());
                    cmd.Parameters.AddWithValue("@HinhThuc", txtHinhThuc.Text.Trim());
                    cmd.Parameters.AddWithValue("@MaKH", txtmaKH.Text.Trim());

                    cmd.ExecuteNonQuery();

                    MessageBox.Show("Sửa đơn hàng thành công!");
                    LoadDonHang();
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi sửa: " + ex.Message);
            }
        }
        private void btnXoa_Click(object sender, EventArgs e)
        {
            if (txtMaDH.Text.Trim() == "")
            {
                MessageBox.Show("Vui lòng chọn đơn hàng để xóa!");
                return;
            }

            if (MessageBox.Show("Bạn có chắc muốn xóa đơn hàng này?",
                                "Xác nhận", MessageBoxButtons.YesNo) == DialogResult.No)
                return;

            try
            {
                using (MySqlConnection conn = new MySqlConnection(connectionString))
                {
                    conn.Open();

                    // Xóa chi tiết trước
                    string delCT = "DELETE FROM ChiTietDonHang WHERE MaDH = @MaDH";
                    MySqlCommand cmdCT = new MySqlCommand(delCT, conn);
                    cmdCT.Parameters.AddWithValue("@MaDH", txtMaDH.Text.Trim());
                    cmdCT.ExecuteNonQuery();

                    // Xóa đơn hàng
                    string delDH = "DELETE FROM DonHang WHERE MaDH = @MaDH";
                    MySqlCommand cmd = new MySqlCommand(delDH, conn);
                    cmd.Parameters.AddWithValue("@MaDH", txtMaDH.Text.Trim());

                    cmd.ExecuteNonQuery();

                    MessageBox.Show("Xóa đơn hàng thành công!");
                    LoadDonHang();
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi xóa: " + ex.Message);
            }
        }
    }
