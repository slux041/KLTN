        private void btnSua_Click(object sender, EventArgs e)
        {
            // Kiểm tra mã lịch hẹn có rỗng không
            if (string.IsNullOrWhiteSpace(txtMaLichHen.Text))
            {
                MessageBox.Show("Vui lòng chọn lịch hẹn để sửa!");
                return;
            }

            try
            {
                using (var conn = new MySqlConnection(connectionString))
                {
                    conn.Open();

                    // Tạo ngày giờ đầy đủ từ dtp + khung giờ
                    DateTime selectedDate = dtpThoiGian.Value.Date;
                    TimeSpan ts;
                    DateTime fullDateTime = selectedDate;
                    string slotText = cmbKhungGio.Text.Trim();
                    if (int.TryParse(slotText, out int hour))
                    {
                        fullDateTime = selectedDate.AddHours(hour);
                    }
                    else if (TimeSpan.TryParse(slotText, out ts))
                    {
                        fullDateTime = selectedDate.Add(ts);
                    }

                    string statusDb = cbTrangThai.Text switch
                    {
                        "Chờ xác nhận" => "pending",
                        "Đã xác nhận" => "confirmed",
                        "Hoàn thành" => "completed",
                        "Đã hủy" => "cancelled",
                        _ => "pending"
                    };

                    // Check for existing appointment in the same date + time slot (exclude current id and cancelled)
                    string checkQuery = @"
                        SELECT COUNT(*)
                        FROM appointments
                        WHERE DATE(appointment_date) = @date
                          AND time_slot = @time_slot
                          AND appointment_id <> @id
                          AND status <> 'cancelled'";

                    var checkCmd = new MySqlCommand(checkQuery, conn);
                    checkCmd.Parameters.AddWithValue("@date", fullDateTime.Date);
                    checkCmd.Parameters.AddWithValue("@time_slot", slotText);
                    checkCmd.Parameters.AddWithValue("@id", Convert.ToInt32(txtMaLichHen.Text));

                    int count = Convert.ToInt32(checkCmd.ExecuteScalar());
                    if (count > 0)
                    {
                        MessageBox.Show("Khung giờ đã có lịch hẹn, vui lòng chọn khung giờ khác!");
                        return;
                    }

                    string sql = @"
                        UPDATE appointments 
                        SET appointment_date = @dateTime,
                            time_slot = @timeSlot,
                            status = @status,
                            service_id = @serviceId,
                            pet_info = @petInfo
                        WHERE appointment_id = @id";

                    var cmd = new MySqlCommand(sql, conn);
                    cmd.Parameters.AddWithValue("@id", Convert.ToInt32(txtMaLichHen.Text));
                    cmd.Parameters.AddWithValue("@dateTime", fullDateTime);
                    cmd.Parameters.AddWithValue("@timeSlot", slotText);
                    cmd.Parameters.AddWithValue("@status", statusDb);
                    cmd.Parameters.AddWithValue("@serviceId", string.IsNullOrWhiteSpace(txtMaDV.Text) ? (object)DBNull.Value : Convert.ToInt32(txtMaDV.Text));
                    cmd.Parameters.AddWithValue("@petInfo", string.IsNullOrWhiteSpace(txtPetinfo.Text) ? (object)DBNull.Value : txtPetinfo.Text);

                    int rows = cmd.ExecuteNonQuery();
                    if (rows > 0)
                    {
                        MessageBox.Show("Cập nhật thành công!");
                        LoadLichHen(txtTimKiem.Text.Trim());
                    }
                    else
                    {
                        MessageBox.Show("Không tìm thấy lịch hẹn!");
                    }
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi: " + ex.Message);
            }
        }
