        private void dgvQLLichHen_CellClick(object sender, DataGridViewCellEventArgs e)
        {
            if (e.RowIndex < 0) return;

            var row = dgvQLLichHen.Rows[e.RowIndex];

            txtMaLichHen.Text = row.Cells["MaLichHen"].Value?.ToString() ?? "";
            txtMaDV.Text = row.Cells["MaDichVu"].Value?.ToString() ?? "";
            txtMaKH.Text = row.Cells["MaKhachHang"].Value?.ToString() ?? "";
            txtPetinfo.Text = row.Cells["ThongTinThuCung"].Value?.ToString() ?? "";
            cmbKhungGio.Text = row.Cells["KhungGio"].Value?.ToString() ?? "";

            // Đặt trạng thái tiếng Việt
            string status = row.Cells["status"].Value?.ToString();
            cbTrangThai.Text = status switch
            {
                "pending" => "Chờ xác nhận",
                "confirmed" => "Đã xác nhận",
                "completed" => "Hoàn thành",
                "cancelled" => "Đã hủy",
                _ => "Chờ xác nhận"
            };

            // Đặt thời gian
            if (DateTime.TryParseExact(row.Cells["ThoiGian"].Value?.ToString(), "dd/MM/yyyy HH:mm", null, System.Globalization.DateTimeStyles.None, out DateTime dt))
            {
                dtpThoiGian.Value = dt;
            }
        }

        private void btnThem_Click(object sender, EventArgs e)
        {
            try
            {
                // basic validation
                if (string.IsNullOrWhiteSpace(txtMaKH.Text))
                {
                    MessageBox.Show("Vui lòng nhập Mã khách hàng.");
                    return;
                }

                using (MySqlConnection conn = new MySqlConnection(connectionString))
                {
                    conn.Open();

                    // compute fullDateTime from selected date and selected slot
                    DateTime selectedDate = dtpThoiGian.Value.Date;
                    TimeSpan ts;
                    DateTime fullDateTime = selectedDate;
                    string slotText = cmbKhungGio.Text.Trim();
                    if (int.TryParse(slotText, out int hour))
                    {
                        fullDateTime = selectedDate.AddHours(hour);
                    }
                    else if (TimeSpan.TryParse(slotText, out ts))
                    {
                        fullDateTime = selectedDate.Add(ts);
                    }

                    // Check for existing appointment in the same date + time slot (exclude cancelled)
                    string checkQuery = @"
                        SELECT COUNT(*)
                        FROM appointments
                        WHERE DATE(appointment_date) = @date
                          AND time_slot = @time_slot
                          AND status <> 'cancelled'";

                    var checkCmd = new MySqlCommand(checkQuery, conn);
                    checkCmd.Parameters.AddWithValue("@date", fullDateTime.Date);
                    checkCmd.Parameters.AddWithValue("@time_slot", slotText);

                    int count = Convert.ToInt32(checkCmd.ExecuteScalar());
                    if (count > 0)
                    {
                        MessageBox.Show("Khung giờ đã có lịch hẹn, vui lòng chọn khung giờ khác!");
                        return;
                    }

                    string query = @"
                        INSERT INTO appointments (customer_id, service_id, pet_info, appointment_date, status, time_slot)
                        VALUES (@customer_id, @service_id, @pet_info, @appointment_date, @status, @time_slot);";

                    MySqlCommand cmd = new MySqlCommand(query, conn);
                    cmd.Parameters.AddWithValue("@customer_id", string.IsNullOrWhiteSpace(txtMaKH.Text) ? (object)DBNull.Value : Convert.ToInt32(txtMaKH.Text));
                    cmd.Parameters.AddWithValue("@service_id", string.IsNullOrWhiteSpace(txtMaDV.Text) ? (object)DBNull.Value : Convert.ToInt32(txtMaDV.Text));
                    cmd.Parameters.AddWithValue("@pet_info", string.IsNullOrWhiteSpace(txtPetinfo.Text) ? (object)DBNull.Value : txtPetinfo.Text);
                    cmd.Parameters.AddWithValue("@appointment_date", fullDateTime);

                    string statusDb = cbTrangThai.Text switch
                    {
                        "Chờ xác nhận" => "pending",
                        "Đã xác nhận" => "confirmed",
                        "Hoàn thành" => "completed",
                        "Đã hủy" => "cancelled",
                        _ => "pending"
                    };
                    cmd.Parameters.AddWithValue("@status", statusDb);
                    cmd.Parameters.AddWithValue("@time_slot", slotText);

                    cmd.ExecuteNonQuery();
                    MessageBox.Show("Thêm lịch hẹn thành công!");
                    LoadLichHen();
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Lỗi khi thêm: " + ex.Message);
            }
        }

