using System;
using System.Data;
using System.Linq;
using System.Windows.Forms;
using MySql.Data.MySqlClient;

namespace GD
{
    public partial class ThongKe : Form
    {
        private readonly string connectionString = "Server=127.0.0.1;Database=spathucung;user=root;password=;";
        private DataTable _currentData;

        public ThongKe()
        {
            InitializeComponent();
            this.Load += ThongKe_Load;
        }

        private string GetQueryInvoices(string dk)
        {
            return $@"
                SELECT
                    inv.invoice_id AS Ma,
                    inv.created_date AS ThoiGian,
                    u.full_name AS KhachHang,
                    IFNULL(inv.total_amount,0) AS SoTien,
                    inv.user_id AS NhanVien
                FROM invoices inv
                JOIN customers c ON inv.customer_id = c.customer_id
                LEFT JOIN users u ON c.user_id = u.user_id
                {dk}
            ";
        }

        private string GetQueryOrders(string dk)
        {
            return $@"
                SELECT
                    o.order_id AS Ma,
                    o.created_at AS ThoiGian,
                    u.full_name AS KhachHang,
                    IFNULL(o.total_amount,0) AS SoTien,
                    o.user_id AS NhanVien
                FROM orders o
                LEFT JOIN users u ON o.user_id = u.user_id
                {dk}
            ";
        }

        private void LoadDoanhThu(string cheDo)
        {
            string dkInv = "";
            string dkOrd = "";

            if (cheDo == "Hôm nay")
            {
                dkInv = "WHERE DATE(inv.created_date) = CURDATE()";
                dkOrd = "WHERE DATE(o.created_at) = CURDATE()";
            }
            else if (cheDo == "7 ngày trước")
            {
                dkInv = "WHERE inv.created_date >= CURDATE() - INTERVAL 7 DAY";
                dkOrd = "WHERE o.created_at >= CURDATE() - INTERVAL 7 DAY";
            }
            else if (cheDo == "1 tháng trước")
            {
                dkInv = "WHERE inv.created_date >= CURDATE() - INTERVAL 30 DAY";
                dkOrd = "WHERE o.created_at >= CURDATE() - INTERVAL 30 DAY";
            }
            else
            {
                dkInv = "";
                dkOrd = "";
            }

            string query = $@"
                SELECT * FROM (
                    {GetQueryInvoices(dkInv)}
                    UNION ALL
                    {GetQueryOrders(dkOrd)}
                ) AS TongHop
                ORDER BY ThoiGian DESC
            ";

            using (MySqlConnection conn = new MySqlConnection(connectionString))
            using (MySqlDataAdapter da = new MySqlDataAdapter(query, conn))
            {
                DataTable dt = new DataTable();
                da.Fill(dt);
                _currentData = dt;
                dgvDoanhThu.DataSource = dt;

                if (dt.Rows.Count == 0)
                {
                    lblNgay.Text = "Không có dữ liệu.";
                    lblTongdoanhthu.Text = "0 đ";
                    return;
                }

                if (dgvDoanhThu.Columns.Contains("Ma"))
                    dgvDoanhThu.Columns["Ma"].HeaderText = "Mã";
                if (dgvDoanhThu.Columns.Contains("ThoiGian"))
                    dgvDoanhThu.Columns["ThoiGian"].HeaderText = "Thời gian";
                if (dgvDoanhThu.Columns.Contains("KhachHang"))
                    dgvDoanhThu.Columns["KhachHang"].HeaderText = "Khách hàng";
                if (dgvDoanhThu.Columns.Contains("SoTien"))
                {
                    dgvDoanhThu.Columns["SoTien"].HeaderText = "Số tiền";
                    dgvDoanhThu.Columns["SoTien"].DefaultCellStyle.Format = "#,###";
                    dgvDoanhThu.Columns["SoTien"].DefaultCellStyle.Alignment = DataGridViewContentAlignment.MiddleRight;
                }
                if (dgvDoanhThu.Columns.Contains("NhanVien"))
                    dgvDoanhThu.Columns["NhanVien"].HeaderText = "Nhân viên";

                // tổng chung
                try
                {
                    decimal total = 0m;
                    if (dt.Columns.Contains("SoTien"))
                    {
                        total = dt.AsEnumerable()
                                  .Where(r => r["SoTien"] != DBNull.Value)
                                  .Sum(r => Convert.ToDecimal(r["SoTien"]));
                    }
                    lblTongdoanhthu.Text = string.Format("{0:N0} đ", total);
                }
                catch
                {
                    lblTongdoanhthu.Text = "0 đ";
                }
            }
        }

        private void ThongKe_Load(object sender, EventArgs e)
        {
            cmbDoanhThu.Items.Add("Hôm nay");
            cmbDoanhThu.Items.Add("7 ngày trước");
            cmbDoanhThu.Items.Add("1 tháng trước");
            cmbDoanhThu.Items.Add("Tất cả");

            cmbDoanhThu.SelectedIndex = 3;
            cmbDoanhThu.SelectedIndex = -1;
            cmbDoanhThu.Text = "";

            LoadDoanhThu("Tất cả");
        }

        private void cmbDoanhThu_SelectedIndexChanged(object sender, EventArgs e)
        {
            if (cmbDoanhThu.SelectedItem != null)
                LoadDoanhThu(cmbDoanhThu.SelectedItem.ToString());
        }

        private void dgvDoanhThu_CellClick(object sender, DataGridViewCellEventArgs e)
        {
            if (e.RowIndex >= 0 && _currentData != null)
            {
                var cell = dgvDoanhThu.Rows[e.RowIndex].Cells["ThoiGian"];
                if (cell?.Value != null)
                {
                    string tg = cell.Value.ToString();
                    lblNgay.Text = "Thời gian: " + tg;

                    // tính tổng theo ngày
                    if (DateTime.TryParse(tg, out DateTime parsed))
                    {
                        DateTime dateOnly = parsed.Date;
                        try
                        {
                            var rowsSameDate = _currentData.AsEnumerable()
                                .Where(r => r["ThoiGian"] != DBNull.Value)
                                .Where(r => DateTime.TryParse(r["ThoiGian"].ToString(), out var d) && d.Date == dateOnly);

                            decimal totalDay = rowsSameDate.Sum(r => Convert.ToDecimal(r["SoTien"]));
                            lblTongdoanhthu.Text = string.Format("{0:N0} đ", totalDay);
                        }
                        catch { }
                    }
                }
            }
        }
    }
}
